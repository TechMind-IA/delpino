# Banco de dados (Neon PostgreSQL)
DATABASE_URL=postgresql://seu_user:seu_password@seu_host/seu_banco

# Better Auth (gere com: openssl rand -base64 32)
BETTER_AUTH_SECRET=sua_chave_secreta_com_32_caracteres
BETTER_AUTH_URL=http://localhost:3000

# App URL (usado em links de reset de senha e verificação de email)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# AWS S3
AWS_ACCESS_KEY_ID=sua_chave_de_acesso
AWS_SECRET_ACCESS_KEY=sua_chave_secreta
AWS_REGION=sa-east-1
AWS_S3_BUCKET_NAME=seu-nome-do-bucket

# Resend (email transacional - https://resend.com)
RESEND_API_KEY=re_sua_chave_api_aqui
RESEND_FROM=Marco Digital de Delpino <noreply@seudominio.com.br>

# Email de destino para mensagens de contato
CONTACT_EMAIL=contato@seudominio.com.br
